    <!-- 删除 -->
    <delete id="deleteById" parameterType="java.lang.Long">
        DELETE FROM
            t_my_special_info
        WHERE
            user_id = #{id}
    </delete>
    <delete id="noCareDelete">
        DELETE FROM
            t_my_special_info
        WHERE
            user_id = #{userId} and business_id =#{projectId} and type =#{type}
    </delete>
    <delete id="deletePageNum">
        DELETE FROM
