    <insert id="insertTrustTradeReservation">
        INSERT INTO T_BUS_TRUST_TRADE_RESERVATION (ID, TRUST_ID, TRUST_CARGO_ID, QUANTITY, TON, START_TIME, END_TIME,
                                                   CUSTOMER_ID, CUSTOMER_NAME, CREATE_BY, CREATE_BY_NAME,
                                                   CREATE_TIME, EXAMINE_BY, EXAMINE_BY_NAME, EXAMINE_TIME)
        VALUES (#{id,jdbcType=BIGINT}, #{trustId, jdbcType=BIGINT},
                #{trustCargoId, jdbcType=BIGINT},
                #{quantity, jdbcType=INTEGER}, #{ton, jdbcType=DECIMAL},
                #{startTime, jdbcType=TIMESTAMP}, #{endTime, jdbcType=TIMESTAMP},
                #{customerId, jdbcType=BIGINT}, #{customerName, jdbcType=VARCHAR},
                #{loginUserId, jdbcType=BIGINT},
                #{loginUserName, jdbcType=VARCHAR}, #{now, jdbcType=TIMESTAMP},
                #{examineBy, jdbcType=BIGINT}, #{examineByName, jdbcType=VARCHAR},
                #{examineTime, jdbcType=TIMESTAMP})
    </insert>

