               TBTTR.STATUS                      TBTTR_STATUS,
               TBTTR.CREATE_BY                   TBTTR_CREATE_BY,
               TBTTR.CREATE_BY_NAME              TBTTR_CREATE_BY_NAME,
               TBTTR.CREATE_TIME                 TBTTR_CREATE_TIME,
               TBTTR.UPDATE_BY                   TBTTR_UPDATE_BY,
               TBTTR.UPDATE_BY_NAME              TBTTR_UPDATE_BY_NAME,
               TBTTR.UPDATE_TIME                 TBTTR_UPDATE_TIME,
               TBTTR.EXAMINE_BY                  TBTTR_EXAMINE_BY,
               TBTTR.EXAMINE_BY_NAME             TBTTR_EXAMINE_BY_NAME,
               TBTTR.EXAMINE_TIME                TBTTR_EXAMINE_TIME,
               TBTTRC.ID                         TBTTRC_ID,
               TBTTRC.TRUST_ID                   TBTTRC_TRUST_ID,
               TBTTRC.TRUST_TRADE_RESERVATION_ID TBTTRC_TTR_ID,
               TBTTRC.CAR_NO                     TBTTRC_CAR_NO,
               TBTTRC.DRIVER_NAME                TBTTRC_DRIVER_NAME,
               TBTTRC.DRIVER_ID_CARD             TBTTRC_DRIVER_ID_CARD,
               TBTTRC.DRIVER_PHONE               TBTTRC_DRIVER_PHONE,
               TBTTRC.STATUS                     TBTTRC_STATUS,
               TBTTRC.CREATE_BY                  TBTTRC_CREATE_BY,
               TBTTRC.CREATE_BY_NAME             TBTTRC_CREATE_BY_NAME,
               TBTTRC.CREATE_TIME                TBTTRC_CREATE_TIME,
               TBTTRC.UPDATE_BY                  TBTTRC_UPDATE_BY,
               TBTTRC.UPDATE_BY_NAME             TBTTRC_UPDATE_BY_NAME,
               TBTTRC.UPDATE_TIME                TBTTRC_UPDATE_TIME,
               TBTC.CARGO_OWNER_ID               TBTC_CARGO_OWNER_ID,
               TBTC.CARGO_OWNER_NAME             TBTC_CARGO_OWNER_NAME,
               TBTC.CARGO_AGENT_ID               TBTC_CARGO_AGENT_ID,
               TBTC.CARGO_AGENT_NAME             TBTC_CARGO_AGENT_NAME,
               TBTC.CARGO_CODE                   TBTC_CARGO_CODE,
               TBTC.CARGO_NAME                   TBTC_CARGO_NAME,
               TBT.TRUST_NO                      TBT_TRUST_NO,
               TBT.PROCESS_CODE                  TBT_PROCESS_CODE,
               TBT.PROCESS_NAME                  TBT_PROCESS_NAME,
               TBT.COMPANY_ID                    TBT_COMPANY_ID,
               TBT.COMPANY_NAME                  TBT_COMPANY_NAME,
               TBT.SHIPVOYAGE_ID                 TBT_SHIPVOYAGE_ID,
               TBT.SHIPVOYAGE_ITEM_ID            TBT_SHIPVOYAGE_ITEM_ID,
               TBT.SHIP_NAME                     TBT_SHIP_NAME,
               TDSI.VOYAGE                       TDSI_VOYAGE
        FROM T_BUS_TRUST_TRADE_RESERVATION TBTTR
                 LEFT JOIN T_BUS_TRUST_TRADE_RESERVAT_CAR TBTTRC on TBTTR.ID = TBTTRC.TRUST_TRADE_RESERVATION_ID
                 JOIN T_BUS_TRUST_CARGO TBTC ON TBTTR.TRUST_CARGO_ID = TBTC.ID
                 JOIN T_BUS_TRUST TBT on TBTC.TRUST_ID = TBT.ID
                 LEFT JOIN T_DIS_SHIPVOYAGE_ITEM TDSI ON TBT.SHIPVOYAGE_ITEM_ID = TDSI.ID
        <where>
            <if test="shipvoyageItemId != null">
                AND TBT.SHIPVOYAGE_ITEM_ID = #{shipvoyageItemId,jdbcType=BIGINT}
            </if>
            <if test="cargoOwnerId != null">
                AND TBTC.CARGO_OWNER_ID = #{cargoOwnerId,jdbcType=BIGINT}
            </if>
            <if test="cargoAgentId != null">
                AND TBTC.CARGO_AGENT_ID = #{cargoAgentId,jdbcType=BIGINT}
            </if>
            <if test="cargoCode != null and cargoCode != ''">
                AND TBTC.CARGO_CODE = #{cargoCode,jdbcType=VARCHAR}
            </if>
        </where>
        ORDER BY TBTTR.CREATE_TIME DESC
    </select>

