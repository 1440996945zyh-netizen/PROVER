        <foreach collection="trustTradeReservatCars" item="entity">
            INTO T_BUS_TRUST_TRADE_RESERVAT_CAR (ID, TRUST_ID, TRUST_TRADE_RESERVATION_ID, CAR_NO,
                                                 DRIVER_NAME, DRIVER_ID_CARD, DRIVER_PHONE, STATUS)
