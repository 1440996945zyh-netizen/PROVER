               TBTC.UPDATE_BY               TBTC_UPDATE_BY,
               TBTC.UPDATE_BY_NAME          TBTC_UPDATE_BY_NAME,
               TBTC.UPDATE_TIME             TBTC_UPDATE_TIME,
               TBT.ID                       TBT_ID,
               TBT.TRUST_NO                 TBT_TRUST_NO,
               TBT.TRUST_TYPE               TBT_TRUST_TYPE,
               TBT.CONTRACT_ID              TBT_CONTRACT_ID,
