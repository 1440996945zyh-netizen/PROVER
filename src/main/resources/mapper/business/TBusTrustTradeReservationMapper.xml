    <select id="getAvailableQuantityAndTon" resultMap="getAvailableQuantityAndTon">
        SELECT SUM(NVL(TBAF.QUANTITY, 0)) - NVL(SUM(TBTTR.QUANTITY), 0) QUANTITY,
               SUM(TBAF.TON) - NVL(SUM(TBTTR.TON), 0)                   TON
        FROM
        T_BUS_ASSIGN_FLEET TBAF
            LEFT JOIN (
        SELECT TRUST_CARGO_ID,
               CUSTOMER_ID,
               SUM(NVL(QUANTITY, 0)) QUANTITY,
               SUM(TON)              TON
        FROM T_BUS_TRUST_TRADE_RESERVATION
        <if test="trustTradeReservationId != null">
            WHERE ID != #{trustTradeReservationId,jdbcType=BIGINT}
        </if>
        GROUP BY TRUST_CARGO_ID,
                 CUSTOMER_ID
        ) TBTTR ON (TBAF.TRUST_CARGO_ID = TBTTR.TRUST_CARGO_ID AND TBAF.CUSTOMER_ID = TBTTR.CUSTOMER_ID)
        WHERE TBAF.ID = #{assignFleetId,jdbcType=BIGINT}
    </select>
