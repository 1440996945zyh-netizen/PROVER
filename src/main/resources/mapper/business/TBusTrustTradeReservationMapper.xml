               TBT.SHIPVOYAGE_ITEM_ID       TBT_SHIPVOYAGE_ITEM_ID,
               TBT.SHIP_NAME                TBT_SHIP_NAME,
               TBT.SETTLEMENT_BASIS_CODE    TBT_SETTLEMENT_BASIS_CODE,
               TBT.SETTLEMENT_BASIS_NAME    TBT_SETTLEMENT_BASIS_NAME,
               TBT.CHECK_TON                TBT_CHECK_TON,
               TBT.CHECK_NUMBER             TBT_CHECK_NUMBER,
               TBT.COMPANY_ID               TBT_COMPANY_ID,
               TBT.COMPANY_NAME             TBT_COMPANY_NAME,
               TBT.STATUS                   TBT_STATUS,
               TBT.CREATE_BY                TBT_CREATE_BY,
               TBT.CREATE_BY_NAME           TBT_CREATE_BY_NAME,
               TBT.CREATE_TIME              TBT_CREATE_TIME,
               TBT.UPDATE_BY                TBT_UPDATE_BY,
               TBT.UPDATE_BY_NAME           TBT_UPDATE_BY_NAME,
               TBT.UPDATE_TIME              TBT_UPDATE_TIME,
               TBT.RELEASE_BY               TBT_RELEASE_BY,
               TBT.RELEASE_BY_NAME          TBT_RELEASE_BY_NAME,
               TBT.RELEASE_TIME             TBT_RELEASE_TIME,
               TBT.CHECK_BY                 TBT_CHECK_BY,
               TBT.CHECK_BY_NAME            TBT_CHECK_BY_NAME,
               TBT.CHECK_TIME               TBT_CHECK_TIME,
               TBT.EXAMINE_BY               TBT_EXAMINE_BY,
               TBT.EXAMINE_BY_NAME          TBT_EXAMINE_BY_NAME,
               TBT.EXAMINE_TIME             TBT_EXAMINE_TIME,
               TBCI.ID                      TBCI_ID,
               TBCI.SHIPVOYAGE_ID           TBCI_SHIPVOYAGE_ID,
               TBCI.SHIPVOYAGE_ITEM_ID      TBCI_SHIPVOYAGE_ITEM_ID,
               TBCI.SCN                     TBCI_SCN,
               TBCI.SHIP_NAME               TBCI_SHIP_NAME,
               TBCI.CARGO_INFO_NO           TBCI_CARGO_INFO_NO,
               TBCI.CARGO_OWNER_ID          TBCI_CARGO_OWNER_ID,
               TBCI.CARGO_OWNER_NAME        TBCI_CARGO_OWNER_NAME,
               TBCI.CARGO_AGENT_ID          TBCI_CARGO_AGENT_ID,
               TBCI.CARGO_AGENT_NAME        TBCI_CARGO_AGENT_NAME,
               TBCI.CARGO_CODE              TBCI_CARGO_CODE,
               TBCI.CARGO_NAME              TBCI_CARGO_NAME,
               TBCI.TRADE_TYPE              TBCI_TRADE_TYPE,
               TBCI.PACKING_CODE            TBCI_PACKING_CODE,
               TBCI.PACKING_NAME            TBCI_PACKING_NAME,
               TBCI.COMPANY_ID              TBCI_COMPANY_ID,
               TBCI.COMPANY_NAME            TBCI_COMPANY_NAME,
               TBCI.PARENT_ID               TBCI_PARENT_ID,
               TBCI.ROOT_ID                 TBCI_ROOT_ID,
               TBCI.QUANTITY                TBCI_QUANTITY,
               TBCI.TON                     TBCI_TON,
               TBCI.RIGHTS_QUANTITY         TBCI_RIGHTS_QUANTITY,
               TBCI.SURPLUS_RIGHTS_QUANTITY TBCI_SURPLUS_RIGHTS_QUANTITY,
               TBCI.IS_CLEAR                TBCI_IS_CLEAR,
               TBCI.CLEAR_BY                TBCI_CLEAR_BY,
               TBCI.CLEAR_BY_NAME           TBCI_CLEAR_BY_NAME,
               TBCI.CLEAR_DATE              TBCI_CLEAR_DATE,
               TBCI.CREATE_BY               TBCI_CREATE_BY,
               TBCI.CREATE_BY_NAME          TBCI_CREATE_BY_NAME,
               TBCI.CREATE_TIME             TBCI_CREATE_TIME,
               TBCI.UPDATE_BY               TBCI_UPDATE_BY,
               TBCI.UPDATE_BY_NAME          TBCI_UPDATE_BY_NAME,
               TBCI.UPDATE_TIME             TBCI_UPDATE_TIME,
               TBAF.ID                      TBAF_ID,
               TBAF.TRUST_ID                TBAF_TRUST_ID,
               TBAF.TRUST_CARGO_ID          TBAF_TRUST_CARGO_ID,
               TBAF.CUSTOMER_ID             TBAF_CUSTOMER_ID,
               TBAF.CUSTOMER_NAME           TBAF_CUSTOMER_NAME,
               TBAF.QUANTITY                TBAF_QUANTITY,
               TBAF.TON                     TBAF_TON,
               TBAF.CREATE_BY               TBAF_CREATE_BY,
               TBAF.CREATE_BY_NAME          TBAF_CREATE_BY_NAME,
               TBAF.CREATE_TIME             TBAF_CREATE_TIME,
               TBAF.UPDATE_BY               TBAF_UPDATE_BY,
               TBAF.UPDATE_BY_NAME          TBAF_UPDATE_BY_NAME,
               TBAF.UPDATE_TIME             TBAF_UPDATE_TIME,
               TDSI.VOYAGE                  TDSI_VOYAGE
        FROM T_BUS_TRUST_CARGO TBTC
                 JOIN T_BUS_TRUST TBT ON TBTC.TRUST_ID = TBT.ID
                 LEFT JOIN T_BUS_CARGO_INFO TBCI ON TBTC.CARGO_INFO_ID = TBCI.ID
                 LEFT JOIN T_BUS_ASSIGN_FLEET TBAF ON TBTC.ID = TBAF.TRUST_CARGO_ID
                 LEFT JOIN T_DIS_SHIPVOYAGE_ITEM TDSI ON TBT.SHIPVOYAGE_ITEM_ID = TDSI.ID
        WHERE TBT.STATUS >= 20
          AND (SUBSTR(PROCESS_NAME, 1, 1) = '车' OR SUBSTR(PROCESS_NAME, - 1) = '车')
        <if test="keyword != null and keyword != ''">
            <bind name="keywordLike" value="'%' + keyword + '%'"/>
            AND TBT.TRUST_NO || '@' || TBT.SHIP_NAME || '_' || TDSI.VOYAGE || '@' || TBT.CARGO_OWNER_NAME || '@' || TBT.CARGO_AGENT_NAME ||
                '@' || TBT.CARGO_NAME LIKE #{keywordLike, jdbcType=VARCHAR}
        </if>
        <if test="trustCargoId != null">
            AND TBTC.ID = #{trustCargoId,jdbcType=BIGINT}
        </if>
        ORDER BY TBT.TRUST_NO,
                 TBCI.CARGO_INFO_NO
    </select>

