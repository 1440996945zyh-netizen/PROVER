<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yy.ppm.businessKH.dao.CargoInfoFhksMapper">



    <select id="getCargoInfoFhksList" resultType="com.yy.ppm.businessKH.model.CargoInfoFhks" parameterType="java.lang.String">
            select distinct CARGOKEY,fhks,khrq,jhy,note from  BT_SHW_CARGOINFO_FHKS
            where  cargokey=#{cargokey}
    </select>

    <select id="getFhksCount" resultType="java.lang.String" parameterType="java.lang.String">
            SELECT COUNT(*) FROM BT_SHW_CARGOINFO_FHKS
            where  cargokey=#{cargokey}
    </select>




</mapper>
